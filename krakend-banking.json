{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "quantum-bank-banking-gateway",
  "port": 8443,
  "tls": {
    "keys": [
      {
        "public_key": "/etc/krakend/tls/gateway-server.crt",
        "private_key": "/etc/krakend/tls/gateway-server.key"
      }
    ],
    "enable_mtls": true,
    "ca_certs": [
      "/etc/krakend/trust/root-ca.crt"
    ]
  },
  "client_tls": {
    "ca_certs": [
      "/etc/krakend/trust/root-ca.crt"
    ],
    "client_certs": [
      {
        "certificate": "/etc/krakend/tls/gateway-client.crt",
        "private_key": "/etc/krakend/tls/gateway-client.key"
      }
    ]
  },
  "endpoints": [
    {
      "endpoint": "/pix/transfers",
      "method": "POST",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "pix:write"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/pix/transfers",
          "method": "POST",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/statements",
      "method": "GET",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "statements:read"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/statements",
          "method": "GET",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/profile",
      "method": "GET",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "profile:read"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/profile",
          "method": "GET",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/profile",
      "method": "PUT",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "profile:write"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/profile",
          "method": "PUT",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    }
  ]
}
