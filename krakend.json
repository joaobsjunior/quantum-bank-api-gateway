{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "quantum-bank-api-gateway-bootstrap-compat",
  "port": 8080,
  "_phase3_mtls_note": "Compatibility entrypoint only. Phase 3 uses krakend-bootstrap.json for OAuth2-only bootstrap and krakend-banking.json for OAuth2 plus app-to-gateway mTLS banking routes.",
  "tls": {
    "keys": [
      {
        "public_key": "/etc/krakend/tls/gateway-server.crt",
        "private_key": "/etc/krakend/tls/gateway-server.key"
      }
    ]
  },
  "client_tls": {
    "ca_certs": [
      "/etc/krakend/trust/root-ca.crt"
    ],
    "client_certs": [
      {
        "certificate": "/etc/krakend/tls/gateway-client.crt",
        "private_key": "/etc/krakend/tls/gateway-client.key"
      }
    ]
  },
  "endpoints": [
    {
      "endpoint": "/auth/otk",
      "method": "POST",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "profile:read"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/auth/otk",
          "method": "POST",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/auth/csr",
      "method": "POST",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/quantum-bank-local/protocol/openid-connect/certs",
          "issuer": "http://keycloak:8080/realms/quantum-bank-local",
          "audience": [
            "quantum-bank-api"
          ],
          "cache": true,
          "disable_jwk_security": true,
          "scopes_key": "scope",
          "scopes_matcher": "all",
          "scopes": [
            "profile:read"
          ],
          "operation_debug": false
        }
      },
      "backend": [
        {
          "host": [
            "https://backend:8080"
          ],
          "url_pattern": "/auth/csr",
          "method": "POST",
          "encoding": "no-op"
        }
      ],
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "output_encoding": "no-op"
    }
  ]
}
